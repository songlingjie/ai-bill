package main

import (
	"ai-demo/config"
	"ai-demo/data"
	"ai-demo/db"
	"ai-demo/handler"
	"ai-demo/service"
	"log"

	"github.com/gin-contrib/cors"
	"github.com/gin-gonic/gin"
)

func main() {
	cfg := config.Load()

	database, err := db.NewDB(cfg.DBDSN)
	if err != nil {
		log.Fatalf("database connect failed: %v", err)
	}
	if err := database.AutoMigrate(&data.Bill{}); err != nil {
		log.Fatalf("database migrate failed: %v", err)
	}

	aiService := service.NewOpenAIService(
		cfg.APIKey,
		cfg.BaseURL,
		cfg.Model,
	)

	chatHandler := handler.NewChatHandler(aiService, database)

	r := gin.Default()
	r.Use(cors.Default())

	r.POST("/chat", chatHandler.Chat)
	r.GET("/bills/today", chatHandler.TodayBill)
	r.GET("/bills/history", chatHandler.HistoryBills)
	r.PUT("/bills/:id", chatHandler.UpdateBill)
	r.DELETE("/bills/:id", chatHandler.DeleteBill)

	r.Run(":" + cfg.Port)
}
