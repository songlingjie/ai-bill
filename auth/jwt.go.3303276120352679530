package auth

import (
	"crypto/hmac"
	"crypto/sha256"
	"encoding/base64"
	"encoding/json"
	"errors"
	"fmt"
	"strings"
	"time"
)

type tokenPayload struct {
	UID int64 `json:"uid"`
	Exp int64 `json:"exp"`
	Iat int64 `json:"iat"`
}

func CreateToken(uid int64, secret string, ttl time.Duration) (string, error) {
	headerBytes, err := json.Marshal(map[string]string{
		"alg": "HS256",
		"typ": "JWT",
	})
	if err != nil {
		return "", err
	}

	now := time.Now()
	payloadBytes, err := json.Marshal(tokenPayload{
		UID: uid,
		Exp: now.Add(ttl).Unix(),
		Iat: now.Unix(),
	})
	if err != nil {
		return "", err
	}

	header := encodeSegment(headerBytes)
	payload := encodeSegment(payloadBytes)
	signingInput := header + "." + payload
	signature := sign(signingInput, secret)
	return signingInput + "." + signature, nil
}

func ParseToken(token, secret string) (int64, error) {
	parts := strings.Split(token, ".")
	if len(parts) != 3 {
		return 0, errors.New("invalid token format")
	}

	expected := sign(parts[0]+"."+parts[1], secret)
	if !hmac.Equal([]byte(expected), []byte(parts[2])) {
		return 0, errors.New("invalid token signature")
	}

	payloadBytes, err := base64.RawURLEncoding.DecodeString(parts[1])
	if err != nil {
		return 0, fmt.Errorf("decode token payload: %w", err)
	}

	var payload tokenPayload
	if err := json.Unmarshal(payloadBytes, &payload); err != nil {
		return 0, fmt.Errorf("parse token payload: %w", err)
	}
	if payload.UID <= 0 {
		return 0, errors.New("invalid token uid")
	}
	if time.Now().Unix() > payload.Exp {
		return 0, errors.New("token expired")
	}

	return payload.UID, nil
}

func encodeSegment(raw []byte) string {
	return base64.RawURLEncoding.EncodeToString(raw)
}

func sign(input, secret string) string {
	mac := hmac.New(sha256.New, []byte(secret))
	mac.Write([]byte(input))
	return base64.RawURLEncoding.EncodeToString(mac.Sum(nil))
}
