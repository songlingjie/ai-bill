package handler

import (
	"ai-demo/data"
	"encoding/json"
	"fmt"
	"net/http"
	"strings"
	"time"

	"github.com/gin-gonic/gin"
	"gorm.io/gorm"

	"ai-demo/service"
)

type ChatHandler struct {
	AI *service.OpenAIService
	DB *gorm.DB
}

type ChatInput struct {
	Message string `json:"message" binding:"required"`
}

type historyBillQuery struct {
	StartDate string `form:"startDate"`
	EndDate   string `form:"endDate"`
	Category  string `form:"category"`
}

type billResponse struct {
	ID          int64   `json:"id"`
	Category    string  `json:"category"`
	Amount      float64 `json:"amount"`
	Type        string  `json:"type"`
	Description string  `json:"description"`
	BillDate    string  `json:"billDate"`
	BillTime    string  `json:"billTime"`
}

func NewChatHandler(aiService *service.OpenAIService, db *gorm.DB) *ChatHandler {
	return &ChatHandler{
		AI: aiService,
		DB: db,
	}
}

func (h *ChatHandler) Chat(c *gin.Context) {
	var input ChatInput

	if err := c.ShouldBindJSON(&input); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{
			"error": err.Error(),
		})
		return
	}

	// result, err := h.AI.Chat(formatInput(input.Message))
	// if err != nil {
	// 	c.JSON(http.StatusInternalServerError, gin.H{
	// 		"error": err.Error(),
	// 	})
	// 	return
	// }
	result := `
	{
        "category": "餐饮",
        "amount": 50,
        "type": "expense",
        "desc": "吃饭",
        "date": "2026-04-09"
    }
`

	var billResp struct {
		Category string  `json:"category"`
		Amount   float64 `json:"amount"`
		Type     string  `json:"type"`
		Desc     string  `json:"desc"`
		Date     string  `json:"date"`
	}

	if err := json.Unmarshal([]byte(result), &billResp); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "解析失败"})
		return
	}

	t, err := time.Parse("2006-01-02", billResp.Date)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "账单日期格式错误"})
		return
	}

	bill := data.Bill{
		UserID:      1,
		Category:    billResp.Category,
		Amount:      billResp.Amount,
		Type:        billResp.Type,
		Description: billResp.Desc,
		BillDate:    t,
	}

	if err := h.DB.Create(&bill).Error; err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "入库失败"})
		return
	}

	c.JSON(http.StatusOK, gin.H{
		"success": true,
		"data":    buildBillResponse(bill),
	})
}

func (h *ChatHandler) TodayBill(c *gin.Context) {
	var bills []data.Bill
	now := time.Now()
	start := time.Date(now.Year(), now.Month(), now.Day(), 0, 0, 0, 0, now.Location())
	end := start.Add(24 * time.Hour)

	h.DB.Where("user_id = ? AND bill_date >= ? AND bill_date < ?", 1, start, end).
		Order("bill_date desc, id desc").
		Find(&bills)

	c.JSON(http.StatusOK, gin.H{
		"success": true,
		"data":    buildBillResponses(bills),
	})
}

func (h *ChatHandler) HistoryBills(c *gin.Context) {
	var query historyBillQuery
	if err := c.ShouldBindQuery(&query); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "查询参数错误"})
		return
	}

	now := time.Now()
	location := now.Location()
	start := time.Date(now.Year(), now.Month(), 1, 0, 0, 0, 0, location)
	end := start.AddDate(0, 1, 0)

	if query.StartDate != "" {
		parsedStart, err := time.ParseInLocation("2006-01-02", query.StartDate, location)
		if err != nil {
			c.JSON(http.StatusBadRequest, gin.H{"error": "startDate 格式应为 YYYY-MM-DD"})
			return
		}
		start = parsedStart
	}

	if query.EndDate != "" {
		parsedEnd, err := time.ParseInLocation("2006-01-02", query.EndDate, location)
		if err != nil {
			c.JSON(http.StatusBadRequest, gin.H{"error": "endDate 格式应为 YYYY-MM-DD"})
			return
		}
		end = parsedEnd.Add(24 * time.Hour)
	}

	if !start.Before(end) {
		c.JSON(http.StatusBadRequest, gin.H{"error": "开始时间不能晚于结束时间"})
		return
	}

	dbQuery := h.DB.Where("user_id = ? AND bill_date >= ? AND bill_date < ?", 1, start, end)
	if category := strings.TrimSpace(query.Category); category != "" && category != "全部" {
		dbQuery = dbQuery.Where("category = ?", category)
	}

	var bills []data.Bill
	if err := dbQuery.Order("bill_date desc, id desc").Find(&bills).Error; err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "查询账单失败"})
		return
	}

	var totalExpense float64
	var totalIncome float64
	for _, bill := range bills {
		if bill.Type == "income" {
			totalIncome += bill.Amount
		} else {
			totalExpense += bill.Amount
		}
	}

	c.JSON(http.StatusOK, gin.H{
		"success": true,
		"data": gin.H{
			"list":         buildBillResponses(bills),
			"total":        len(bills),
			"totalExpense": totalExpense,
			"totalIncome":  totalIncome,
		},
	})
}

func buildBillResponses(bills []data.Bill) []billResponse {
	result := make([]billResponse, 0, len(bills))
	for _, bill := range bills {
		result = append(result, buildBillResponse(bill))
	}
	return result
}

func buildBillResponse(bill data.Bill) billResponse {
	return billResponse{
		ID:          bill.ID,
		Category:    bill.Category,
		Amount:      bill.Amount,
		Type:        bill.Type,
		Description: bill.Description,
		BillDate:    bill.BillDate.Format("2006-01-02"),
		BillTime:    bill.BillDate.Format("15:04"),
	}
}

func formatInput(s string) string {
	return fmt.Sprintf(`请提取记账信息，并返回 JSON：
{
  "category": "分类",
  "amount": 金额,
  "type": "expense 或 income",
  "desc": "描述",
  "date": "YYYY-MM-DD"
}
分类只能是：
餐饮/交通/购物/娱乐/其他/工资
只返回 JSON，不要解释：
用户输入：%s
`, s)
}
