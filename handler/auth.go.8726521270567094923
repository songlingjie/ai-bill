package handler

import (
	"ai-demo/auth"
	"ai-demo/data"
	"ai-demo/service"
	"net/http"
	"strings"
	"time"

	"github.com/gin-gonic/gin"
	"gorm.io/gorm"
)

type AuthHandler struct {
	DB        *gorm.DB
	WeChat    *service.WeChatService
	JWTSecret string
}

type LoginInput struct {
	Code      string `json:"code" binding:"required"`
	NickName  string `json:"nickName"`
	AvatarURL string `json:"avatarUrl"`
}

func NewAuthHandler(db *gorm.DB, wechat *service.WeChatService, jwtSecret string) *AuthHandler {
	return &AuthHandler{
		DB:        db,
		WeChat:    wechat,
		JWTSecret: jwtSecret,
	}
}

func (h *AuthHandler) Login(c *gin.Context) {
	var input LoginInput
	if err := c.ShouldBindJSON(&input); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "登录参数错误"})
		return
	}

	openID, err := h.WeChat.Code2Session(strings.TrimSpace(input.Code))
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	var user data.User
	err = h.DB.Where("open_id = ?", openID).First(&user).Error
	if err != nil && err != gorm.ErrRecordNotFound {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "查询用户失败"})
		return
	}

	nickName := strings.TrimSpace(input.NickName)
	avatarURL := strings.TrimSpace(input.AvatarURL)
	if err == gorm.ErrRecordNotFound {
		user = data.User{
			OpenID:    openID,
			NickName:  nickName,
			AvatarURL: avatarURL,
		}
		if user.NickName == "" {
			user.NickName = "微信用户"
		}
		if err := h.DB.Create(&user).Error; err != nil {
			c.JSON(http.StatusInternalServerError, gin.H{"error": "创建用户失败"})
			return
		}
	} else {
		needUpdate := false
		if nickName != "" && nickName != user.NickName {
			user.NickName = nickName
			needUpdate = true
		}
		if avatarURL != "" && avatarURL != user.AvatarURL {
			user.AvatarURL = avatarURL
			needUpdate = true
		}
		if needUpdate {
			if err := h.DB.Save(&user).Error; err != nil {
				c.JSON(http.StatusInternalServerError, gin.H{"error": "更新用户信息失败"})
				return
			}
		}
	}

	token, err := auth.CreateToken(user.ID, h.JWTSecret, 7*24*time.Hour)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "生成登录凭证失败"})
		return
	}

	c.JSON(http.StatusOK, gin.H{
		"success": true,
		"data": gin.H{
			"jwtToken":  token,
			"userId":    user.ID,
			"nickName":  user.NickName,
			"avatarUrl": user.AvatarURL,
		},
	})
}
